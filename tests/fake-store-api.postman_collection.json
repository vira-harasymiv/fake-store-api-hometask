          "name": "getProducts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "\r",
                  "pm.collectionVariables.set(\"title\", response[0].title);\r",
                  "\r",
                  "pm.collectionVariables.set(\"price\", response[0].price);\r",
                  "\r",
                  "pm.collectionVariables.set(\"category\", response[0].category.slug);\r",
                  "\r",
                  "pm.collectionVariables.set(\"categoryId\", response[0].category.id)\r",
                  "\r",
                  "const arrayWithSelectedTitle = response.filter(product => product.title === response[0].title);\r",
                  "\r",
                  "pm.collectionVariables.set(\"arrayWithSelectedTitle\", JSON.stringify(arrayWithSelectedTitle));\r",
                  "\r",
                  "console.log(arrayWithSelectedTitle);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products"]
            }
          },
          "response": []

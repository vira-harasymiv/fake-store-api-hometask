        {
          "name": "filterByTitle",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "const title = pm.collectionVariables.get(\"title\");\r",
                  "const arrayWithSelectedTitle = pm.collectionVariables.get(\"arrayWithSelectedTitle\");\r",
                  "\r",
                  "console.log(typeof arrayWithSelectedTitle)\r",
                  "\r",
                  "pm.test(\"Producs are filtered by title\", () => {\r",
                  "    pm.expect(response.length).to.be.at.least(1);\r",
                  "    for (const product of response) {\r",
                  "        pm.expect(product.title).to.eql(title);\r",
                  "    }\r",
                  "}\r",
                  ")\r",
                  "\r",
                  "pm.test(\"All filtered results are shown\", () => {\r",
                  "    pm.expect(response).to.eql(JSON.parse(arrayWithSelectedTitle));\r",
                  "});\r",
                  "\r",
                  ""
